// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // A URL foi movida para o prisma.config.ts conforme nova norma v7
}

// --- INTEGRIDADE FUNCIONAL: RBAC ENUMS ---

enum UserRole {
  SUPER_ADMIN
  MASTER_CAMPO
  REGIONAL
  GESTOR
  ALUNO
}

// --- INTEGRIDADE FUNCIONAL: MODELAGEM MASTER ---

model UserProfile {
  id        String   @id @default(uuid())
  email     String   @unique
  role      UserRole @default(ALUNO)
  target_id String?  // ID da Unidade/Igreja/Curso vinculado
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admin_roles") // Mapeia para o nome definido no Blueprint (RBAC)
}